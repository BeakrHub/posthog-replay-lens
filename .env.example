# Required: PostHog personal API key with session_recording:read.
POSTHOG_PERSONAL_API_KEY=

# Optional: project ID. If omitted, the app picks the first project visible to the key,
# or matches POSTHOG_PROJECT_TOKEN when provided.
POSTHOG_PROJECT_ID=
POSTHOG_PROJECT_TOKEN=
POSTHOG_API_HOST=https://us.posthog.com

# Required for analysis.
# Use "ai-studio" for GOOGLE_AI_API_KEY, or "vertex-ai" for GCP Vertex AI.
GEMINI_PROVIDER=ai-studio
GOOGLE_AI_API_KEY=
GEMINI_REPLAY_MODEL=gemini-3.5-flash

# Optional: password-gate the web UI, API, and generated replay artifacts.
REPLAY_LENS_PASSWORD=
REPLAY_LENS_PUBLIC_URL=

# Optional: built-in scheduled automation loop. When enabled, the server runs
# unattended batches on this cadence, skips previously seen recording IDs, stores
# merged issues under artifacts/automation/state.json, and can send Slack alerts.
AUTOMATION_ENABLED=false
AUTOMATION_RUN_ON_START=false
AUTOMATION_INTERVAL_HOURS=5
AUTOMATION_COUNT=10
AUTOMATION_PARALLELISM=2
AUTOMATION_CANDIDATE_LIMIT=150
AUTOMATION_SPEED=12
AUTOMATION_MIN_RECORDING_SECONDS=60
AUTOMATION_MIN_ACTIVE_SECONDS=20
AUTOMATION_MIN_ACTIVITY_SCORE=10
AUTOMATION_MIN_CLICKS=0
AUTOMATION_MAX_PER_USER=1
AUTOMATION_MAX_AGE_DAYS=7
AUTOMATION_INCLUDE_ONGOING=false
AUTOMATION_FILTER_STALE_RECORDINGS=true
AUTOMATION_DEDUPE_SIMILAR=true
AUTOMATION_DIVERSIFY_USERS=true
AUTOMATION_MIN_CLIP_SECONDS=12
AUTOMATION_MAX_CLIP_SECONDS=45
AUTOMATION_URL_INCLUDES=
AUTOMATION_URL_EXCLUDES=
AUTOMATION_USER_INCLUDES=
AUTOMATION_GEMINI_MODEL=
AUTOMATION_ANALYSIS_FOCUS=
SLACK_WEBHOOK_URL=
SLACK_MENTION=

# Optional: Vertex AI / GCP mode. VERTEX_AI_ACCESS_TOKEN may be omitted when
# local gcloud application-default credentials are available.
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=global
VERTEX_AI_ACCESS_TOKEN=

# Runtime knobs.
PORT=8787
POSTHOG_SNAPSHOT_CHUNK_SIZE=20
POSTHOG_MAX_THROTTLE_WAIT_SECONDS=0
